@page "/ventas"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject TiendaRopaDbContext db
@inject IHttpClientFactory ClientFactory

<PageTitle>Ventas - StyleShop</PageTitle>

<div style="max-width: 980px; margin: 36px auto; padding: 0 24px 64px;">

    <h1 style="color: #6B4F35; margin-bottom: 6px; font-size: 1.9rem; font-weight: 700;">
        🧾 Registro de Ventas
    </h1>
    <p style="color: #8B7355; margin-bottom: 28px;">
        Combina clientes de tu base de datos con productos del catálogo de la API.
    </p>

    <div style="display: flex; gap: 12px; margin-bottom: 28px; font-size: 0.83rem; flex-wrap: wrap;">
        <span style="background: #F0E6D3; color: #8B6F47; padding: 4px 12px; border-radius: 10px; font-weight: 600;">
            📦 Clientes → Tu BD
        </span>
        <span style="background: #E8F0F5; color: #5B7A9D; padding: 4px 12px; border-radius: 10px; font-weight: 600;">
            🌐 Productos → API del Profesor
        </span>
    </div>

    <!-- ===== FORMULARIO NUEVA VENTA ===== -->
    <div style="background: white; padding: 28px; border-radius: 14px; margin-bottom: 28px;
        border: 2px solid #C4A882; box-shadow: 0 2px 10px rgba(139,111,71,0.1);">
        <h3 style="color: #6B4F35; margin-bottom: 22px; font-size: 1.15rem;">➕ Nueva Venta</h3>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px;">

            <!-- Cliente de la BD -->
            <div>
                <label style="display: block; margin-bottom: 5px; font-weight: 600; color: #4A3728;">
                    👥 Cliente <span style="color: #C62828;">*</span>
                    <span style="font-size: 0.72rem; font-weight: 400; color: #B8A89A; margin-left: 4px;">(Tu BD)</span>
                </label>
                <select @bind="nuevaVenta.ClienteId"
                        style="width: 100%; padding: 10px 12px; border: 2px solid #C4A882;
                        border-radius: 8px; font-size: 0.95rem; background: #FDF9F5; color: #4A3728; box-sizing: border-box;">
                    <option value="0">— Selecciona un cliente —</option>
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>

            <div>
                <label style="display: block; margin-bottom: 5px; font-weight: 600; color: #4A3728;">
                    Estado
                </label>
                <select @bind="nuevaVenta.Estado"
                        style="width: 100%; padding: 10px 12px; border: 2px solid #C4A882;
                        border-radius: 8px; font-size: 0.95rem; background: #FDF9F5; color: #4A3728; box-sizing: border-box;">
                    <option value="Completada">Completada</option>
                    <option value="Pendiente">Pendiente</option>
                    <option value="Cancelada">Cancelada</option>
                </select>
            </div>

        </div>

        <!-- Selección de producto de la API -->
        <div style="border: 2px solid #D4B896; border-radius: 10px; padding: 18px; margin-bottom: 18px;
            background: #FDF9F5;">
            <h4 style="color: #6B4F35; margin: 0 0 14px; font-size: 0.97rem;">
                🌐 Seleccionar producto (API del Profesor)
            </h4>

            @if (productosApi == null)
            {
                <p style="color: #8B7355; font-size: 0.9rem;">⏳ Cargando productos de la API...</p>
            }
            else
            {
                <div style="display: grid; grid-template-columns: 1fr auto auto auto; gap: 12px; align-items: flex-end;">
                    <div>
                        <label style="display: block; margin-bottom: 5px; font-weight: 600; color: #4A3728; font-size: 0.9rem;">
                            Producto <span style="color: #C62828;">*</span>
                        </label>
                        <select @bind="productoSeleccionadoId"
                                style="width: 100%; padding: 10px 12px; border: 2px solid #C4A882;
                                border-radius: 8px; font-size: 0.9rem; background: white; color: #4A3728; box-sizing: border-box;">
                            <option value="0">— Selecciona un producto —</option>
                            @foreach (var p in productosApi)
                            {
                                var cat = p.CategoriaId == 1 ? "Mujer" : "Hombre";
                                <option value="@p.Id">[@cat] @p.Nombre — $@p.Precio.ToString("F2")</option>
                            }
                        </select>
                    </div>
                    <div style="min-width: 80px;">
                        <label style="display: block; margin-bottom: 5px; font-weight: 600; color: #4A3728; font-size: 0.9rem;">
                            Cantidad
                        </label>
                        <input @bind="cantidadProducto" type="number" min="1"
                               style="width: 80px; padding: 10px 8px; border: 2px solid #C4A882;
                               border-radius: 8px; font-size: 0.9rem; background: white; color: #4A3728;" />
                    </div>
                    <div style="padding-bottom: 2px;">
                        <button @onclick="AgregarProductoAVenta"
                                style="background: #C4A882; color: #4A3728; padding: 10px 18px;
                                border: none; border-radius: 8px; font-weight: 700; cursor: pointer; white-space: nowrap;">
                            ➕ Agregar
                        </button>
                    </div>
                </div>
            }
        </div>

        <!-- Detalle de la venta -->
        @if (detallesTemporal.Count > 0)
        {
            <div style="background: #F5F0E8; border-radius: 10px; padding: 16px; margin-bottom: 18px;">
                <h4 style="color: #6B4F35; margin: 0 0 12px; font-size: 0.95rem;">🛒 Productos en esta venta</h4>
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                    <thead>
                        <tr style="color: #6B4F35;">
                            <th style="text-align: left; padding: 6px 10px;">Producto</th>
                            <th style="text-align: center; padding: 6px 10px;">Cant.</th>
                            <th style="text-align: right; padding: 6px 10px;">Precio Unit.</th>
                            <th style="text-align: right; padding: 6px 10px;">Subtotal</th>
                            <th style="text-align: center; padding: 6px 10px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in detallesTemporal)
                        {
                            <tr style="border-bottom: 1px solid #E8D5B7;">
                                <td style="padding: 8px 10px; color: #4A3728; font-weight: 500;">@d.ProductoNombre</td>
                                <td style="padding: 8px 10px; text-align: center;">@d.Cantidad</td>
                                <td style="padding: 8px 10px; text-align: right;">$@d.Precio.ToString("F2")</td>
                                <td style="padding: 8px 10px; text-align: right; font-weight: 700; color: #6B4F35;">
                                    $@((d.Precio * d.Cantidad).ToString("F2"))
                                </td>
                                <td style="padding: 8px 10px; text-align: center;">
                                    <button @onclick="() => detallesTemporal.Remove(d)"
                                            style="background: #EF9A9A; color: #B71C1C; border: none;
                                            padding: 3px 10px; border-radius: 6px; cursor: pointer; font-size: 0.82rem;">
                                        ✕
                                    </button>
                                </td>
                            </tr>
                        }
                        <tr style="border-top: 2px solid #C4A882; font-weight: 800;">
                            <td colspan="3" style="padding: 10px 10px; text-align: right; color: #6B4F35;">TOTAL:</td>
                            <td style="padding: 10px 10px; text-align: right; color: #6B4F35; font-size: 1.1rem;">
                                $@detallesTemporal.Sum(d => d.Precio * d.Cantidad).ToString("F2")
                            </td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <div style="background: #FFEBEE; color: #C62828; padding: 12px 16px; border-radius: 8px; margin-bottom: 14px; font-weight: 500;">
                ⚠️ @mensajeError
            </div>
        }
        @if (!string.IsNullOrEmpty(mensajeExito))
        {
            <div style="background: #E8F5E9; color: #2E7D32; padding: 12px 16px; border-radius: 8px; margin-bottom: 14px; font-weight: 500;">
                ✅ @mensajeExito
            </div>
        }

        <button @onclick="GuardarVenta"
                style="background: #6B4F35; color: #F5F0E8; padding: 12px 32px;
                border: none; border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 0.95rem;">
            💾 Guardar Venta
        </button>
    </div>

    <!-- ===== HISTORIAL DE VENTAS ===== -->
    <div style="background: white; padding: 24px; border-radius: 14px;
        border: 2px solid #C4A882; box-shadow: 0 2px 8px rgba(139,111,71,0.08);">
        <h3 style="color: #6B4F35; margin-bottom: 18px;">📋 Historial de Ventas (@ventas.Count)</h3>

        @if (ventas.Count == 0)
        {
            <p style="color: #B8A89A; text-align: center; padding: 40px;">No hay ventas registradas aún.</p>
        }
        else
        {
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
                    <thead>
                        <tr style="background: #8B6F47; color: #F5F0E8;">
                            <th style="padding: 12px 14px; text-align: left;">ID</th>
                            <th style="padding: 12px 14px; text-align: left;">Cliente</th>
                            <th style="padding: 12px 14px; text-align: left;">Fecha</th>
                            <th style="padding: 12px 14px; text-align: right;">Total</th>
                            <th style="padding: 12px 14px; text-align: center;">Estado</th>
                            <th style="padding: 12px 14px; text-align: left;">Productos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venta in ventas)
                        {
                            var idx = ventas.IndexOf(venta);
                            <tr style="border-bottom: 1px solid #E8D5B7; background: @(idx % 2 == 0 ? "white" : "#FDF9F5");">
                                <td style="padding: 12px 14px; color: #9E9E9E;">#@venta.Id</td>
                                <td style="padding: 12px 14px; font-weight: 600; color: #4A3728;">
                                    @(venta.Cliente?.Nombre ?? "—")
                                </td>
                                <td style="padding: 12px 14px; color: #6B5344;">
                                    @venta.Fecha.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td style="padding: 12px 14px; text-align: right; font-weight: 700; color: #6B4F35;">
                                    $@venta.Total.ToString("F2")
                                </td>
                                <td style="padding: 12px 14px; text-align: center;">
                                    @{
                                        var badgeBg = venta.Estado == "Completada" ? "#E8F5E9" : venta.Estado == "Pendiente" ? "#FFF8E1" : "#FFEBEE";
                                        var badgeColor = venta.Estado == "Completada" ? "#2E7D32" : venta.Estado == "Pendiente" ? "#F57F17" : "#C62828";
                                    }
                                    <span style="background: @badgeBg; color: @badgeColor; padding: 4px 12px;
                                        border-radius: 10px; font-size: 0.82rem; font-weight: 600;">
                                        @venta.Estado
                                    </span>
                                </td>
                                <td style="padding: 12px 14px; color: #6B5344; font-size: 0.85rem;">
                                    @string.Join(", ", venta.Detalles.Select(d => $"{d.ProductoNombre} x{d.Cantidad}"))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Cliente> clientes = new();
    private List<ProductoApi>? productosApi = null;
    private List<Venta> ventas = new();
    private List<DetalleVenta> detallesTemporal = new();

    private Venta nuevaVenta = new() { Estado = "Completada" };
    private int productoSeleccionadoId = 0;
    private int cantidadProducto = 1;

    private string mensajeError = "";
    private string mensajeExito = "";

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
        await CargarVentas();
        await CargarProductosApi();
    }

    private async Task CargarClientes()
    {
        clientes = await db.Clientes.OrderBy(c => c.Nombre).ToListAsync();
    }

    private async Task CargarVentas()
    {
        ventas = await db.Ventas
            .Include(v => v.Cliente)
            .Include(v => v.Detalles)
            .OrderByDescending(v => v.Fecha)
            .ToListAsync();
    }

    private async Task CargarProductosApi()
    {
        try
        {
            var http = ClientFactory.CreateClient("ApiProfesor");
            var mujer = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/1");
            var hombre = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/2");
            productosApi = new List<ProductoApi>();
            if (mujer != null) productosApi.AddRange(mujer);
            if (hombre != null) productosApi.AddRange(hombre);
        }
        catch
        {
            productosApi = new List<ProductoApi>();
        }
    }

    private void AgregarProductoAVenta()
    {
        mensajeError = "";
        if (productoSeleccionadoId == 0)
        {
            mensajeError = "Selecciona un producto de la API.";
            return;
        }
        if (cantidadProducto <= 0)
        {
            mensajeError = "La cantidad debe ser mayor a 0.";
            return;
        }

        var producto = productosApi?.FirstOrDefault(p => p.Id == productoSeleccionadoId);
        if (producto == null) return;

        // Si ya existe, sumar cantidad
        var existente = detallesTemporal.FirstOrDefault(d => d.ProductoApiId == producto.Id);
        if (existente != null)
        {
            existente.Cantidad += cantidadProducto;
        }
        else
        {
            detallesTemporal.Add(new DetalleVenta
            {
                ProductoApiId = producto.Id,
                ProductoNombre = producto.Nombre,
                Cantidad = cantidadProducto,
                Precio = producto.Precio
            });
        }

        productoSeleccionadoId = 0;
        cantidadProducto = 1;
    }

    private async Task GuardarVenta()
    {
        mensajeError = "";
        mensajeExito = "";

        if (nuevaVenta.ClienteId == 0)
        {
            mensajeError = "Debes seleccionar un cliente.";
            return;
        }
        if (detallesTemporal.Count == 0)
        {
            mensajeError = "Agrega al menos un producto a la venta.";
            return;
        }

        nuevaVenta.Fecha = DateTime.Now;
        nuevaVenta.Total = detallesTemporal.Sum(d => d.Precio * d.Cantidad);
        nuevaVenta.Detalles = detallesTemporal.ToList();

        db.Ventas.Add(nuevaVenta);
        await db.SaveChangesAsync();

        mensajeExito = $"Venta #{nuevaVenta.Id} registrada correctamente por ${nuevaVenta.Total:F2}.";

        nuevaVenta = new Venta { Estado = "Completada" };
        detallesTemporal.Clear();
        productoSeleccionadoId = 0;

        await CargarVentas();
    }
}
