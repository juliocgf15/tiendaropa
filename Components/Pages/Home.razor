@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject TiendaRopaDbContext db
@inject IHttpClientFactory ClientFactory

<PageTitle>Inicio - StyleShop</PageTitle>

<!-- ===== HERO ===== -->
<div style="background: linear-gradient(135deg, #8B6F47 0%, #C4A882 100%);
    color: #F5F0E8; padding: 60px 40px; text-align: center; border-radius: 0 0 24px 24px;">

    <div style="font-size: 4rem; margin-bottom: 16px;">👗</div>

    <h1 style="font-size: 2.5rem; font-weight: 700; margin: 0 0 12px; color: #F5F0E8;">
        Bienvenido a StyleShop
    </h1>

    <p style="font-size: 1.15rem; max-width: 560px; margin: 0 auto 32px; opacity: 0.92; line-height: 1.6;">
        Tu tienda de moda favorita. Encuentra las últimas tendencias en ropa
        para toda la familia con la mejor calidad y precio.
    </p>
</div>

<!-- ===== INDICADORES ===== -->
<div style="max-width: 900px; margin: 40px auto; padding: 0 24px;">

    <h2 style="color: #6B4F35; text-align: center; font-size: 1.5rem; margin-bottom: 28px;">
        📊 Resumen del Sistema
    </h2>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 48px;">

        <!-- Dato de la BD propia -->
        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #C4A882; box-shadow: 0 4px 12px rgba(139,111,71,0.12);">
            <div style="font-size: 2.5rem; margin-bottom: 8px;">👥</div>
            <div style="font-size: 2.2rem; font-weight: 800; color: #6B4F35;">
                @(cargandoBD ? "..." : totalClientes.ToString())
            </div>
            <div style="color: #8B6F47; font-weight: 600; font-size: 0.95rem;">Clientes Registrados</div>
            <div style="font-size: 0.75rem; color: #B8A89A; margin-top: 4px;">📦 Tu base de datos</div>
        </div>

        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #C4A882; box-shadow: 0 4px 12px rgba(139,111,71,0.12);">
            <div style="font-size: 2.5rem; margin-bottom: 8px;">🧾</div>
            <div style="font-size: 2.2rem; font-weight: 800; color: #6B4F35;">
                @(cargandoBD ? "..." : totalVentas.ToString())
            </div>
            <div style="color: #8B6F47; font-weight: 600; font-size: 0.95rem;">Ventas Realizadas</div>
            <div style="font-size: 0.75rem; color: #B8A89A; margin-top: 4px;">📦 Tu base de datos</div>
        </div>

        <!-- Dato de la API del profesor -->
        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #D4B896; box-shadow: 0 4px 12px rgba(139,111,71,0.12);">
            <div style="font-size: 2.5rem; margin-bottom: 8px;">👕</div>
            <div style="font-size: 2.2rem; font-weight: 800; color: #6B4F35;">
                @(cargandoApi ? "..." : totalProductos.ToString())
            </div>
            <div style="color: #8B6F47; font-weight: 600; font-size: 0.95rem;">Prendas en Catálogo</div>
            <div style="font-size: 0.75rem; color: #B8A89A; margin-top: 4px;">👗 Mujer + 👔 Hombre</div>
        </div>

        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #D4B896; box-shadow: 0 4px 12px rgba(139,111,71,0.12);">
            <div style="font-size: 2.5rem; margin-bottom: 8px;">🏷️</div>
            <div style="font-size: 2.2rem; font-weight: 800; color: #6B4F35;">
                @(cargandoApi ? "..." : totalCategorias.ToString())
            </div>
            <div style="color: #8B6F47; font-weight: 600; font-size: 0.95rem;">Categorías de Ropa</div>
            <div style="font-size: 0.75rem; color: #B8A89A; margin-top: 4px;">👩 Mujer · 👨 Hombre</div>
        </div>

    </div>

    <!-- ===== ACCESOS RÁPIDOS ===== -->
    <h2 style="color: #6B4F35; text-align: center; font-size: 1.5rem; margin-bottom: 8px;">
        Módulos del Sistema
    </h2>
    <p style="text-align: center; color: #8B7355; margin-bottom: 32px;">
        Accede directamente a cada sección de la tienda.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">

        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #C4A882; box-shadow: 0 2px 8px rgba(139,111,71,0.1);">
            <div style="font-size: 2.8rem; margin-bottom: 12px;">🛍️</div>
            <h3 style="color: #6B4F35; font-size: 1.05rem; margin: 0 0 10px;">Catálogo de Ropa</h3>
            <p style="color: #8B7355; font-size: 0.87rem; margin: 0 0 18px; line-height: 1.5;">
                Explora todos los productos disponibles consumidos desde la API del profesor.
            </p>
            <a href="/catalogo" style="display: inline-block; background: #8B6F47; color: #F5F0E8;
                font-weight: 700; font-size: 0.9rem; padding: 10px 24px;
                border-radius: 50px; text-decoration: none;">
                Ver Catálogo →
            </a>
        </div>

        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #C4A882; box-shadow: 0 2px 8px rgba(139,111,71,0.1);">
            <div style="font-size: 2.8rem; margin-bottom: 12px;">👥</div>
            <h3 style="color: #6B4F35; font-size: 1.05rem; margin: 0 0 10px;">Gestión de Clientes</h3>
            <p style="color: #8B7355; font-size: 0.87rem; margin: 0 0 18px; line-height: 1.5;">
                Registra, edita y administra la base de datos de clientes de la tienda.
            </p>
            <a href="/clientes" style="display: inline-block; background: #8B6F47; color: #F5F0E8;
                font-weight: 700; font-size: 0.9rem; padding: 10px 24px;
                border-radius: 50px; text-decoration: none;">
                Ver Clientes →
            </a>
        </div>

        <div style="background: white; border-radius: 14px; padding: 28px 20px; text-align: center;
            border: 2px solid #C4A882; box-shadow: 0 2px 8px rgba(139,111,71,0.1);">
            <div style="font-size: 2.8rem; margin-bottom: 12px;">🧾</div>
            <h3 style="color: #6B4F35; font-size: 1.05rem; margin: 0 0 10px;">Registro de Ventas</h3>
            <p style="color: #8B7355; font-size: 0.87rem; margin: 0 0 18px; line-height: 1.5;">
                Registra ventas combinando clientes de tu BD con productos de la API.
            </p>
            <a href="/ventas" style="display: inline-block; background: #8B6F47; color: #F5F0E8;
                font-weight: 700; font-size: 0.9rem; padding: 10px 24px;
                border-radius: 50px; text-decoration: none;">
                Ver Ventas →
            </a>
        </div>

    </div>
</div>

@code {
    private int totalClientes = 0;
    private int totalVentas = 0;
    private int totalProductos = 0;
    private int totalCategorias = 0;
    private bool cargandoBD = true;
    private bool cargandoApi = true;

    protected override async Task OnInitializedAsync()
    {
        // Datos de la BD propia
        totalClientes = await db.Clientes.CountAsync();
        totalVentas = await db.Ventas.CountAsync();
        cargandoBD = false;

        // Datos de la API del profesor — solo ropa de mujer (1) y hombre (2)
        try
        {
            var http = ClientFactory.CreateClient("ApiProfesor");
            var mujer = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/1");
            var hombre = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/2");
            totalProductos = (mujer?.Count ?? 0) + (hombre?.Count ?? 0);
            totalCategorias = 2;
        }
        catch
        {
            totalProductos = 0;
            totalCategorias = 0;
        }
        cargandoApi = false;
    }
}
