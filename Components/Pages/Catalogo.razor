@page "/catalogo"
@rendermode InteractiveServer
@inject IHttpClientFactory ClientFactory

<PageTitle>Catálogo - StyleShop</PageTitle>

<div style="max-width: 1000px; margin: 36px auto; padding: 0 24px 64px;">

    <div style="text-align: center; margin-bottom: 32px;">
        <h1 style="color: #6B4F35; font-size: 2rem; font-weight: 700; margin-bottom: 8px;">
            🛍️ Catálogo de Ropa
        </h1>
        <p style="color: #8B7355; font-size: 1rem;">
            Productos obtenidos en tiempo real desde la API del profesor
            <span style="background: #F0E6D3; color: #8B6F47; padding: 2px 10px; border-radius: 10px;
                font-size: 0.78rem; font-weight: 600; margin-left: 8px;">🌐 API Externa</span>
        </p>
    </div>

    <!-- ===== BOTONES DE FILTRO ===== -->
    <div style="display: flex; justify-content: center; gap: 16px; margin-bottom: 32px; flex-wrap: wrap;">

        <button @onclick='() => FiltrarCategoria(0)'
                style="padding: 12px 28px; border-radius: 50px; font-size: 0.95rem; font-weight: 700;
                cursor: pointer; border: 2px solid #C4A882; transition: all 0.2s;
                background: @(categoriaActiva == 0 ? "#8B6F47" : "white");
                color: @(categoriaActiva == 0 ? "#F5F0E8" : "#6B4F35");">
            👗 Todo
        </button>

        <button @onclick='() => FiltrarCategoria(1)'
                style="padding: 12px 28px; border-radius: 50px; font-size: 0.95rem; font-weight: 700;
                cursor: pointer; border: 2px solid #C4A882; transition: all 0.2s;
                background: @(categoriaActiva == 1 ? "#8B6F47" : "white");
                color: @(categoriaActiva == 1 ? "#F5F0E8" : "#6B4F35");">
            👩 Ropa de Mujer
        </button>

        <button @onclick='() => FiltrarCategoria(2)'
                style="padding: 12px 28px; border-radius: 50px; font-size: 0.95rem; font-weight: 700;
                cursor: pointer; border: 2px solid #C4A882; transition: all 0.2s;
                background: @(categoriaActiva == 2 ? "#8B6F47" : "white");
                color: @(categoriaActiva == 2 ? "#F5F0E8" : "#6B4F35");">
            👨 Ropa de Hombre
        </button>

    </div>

    <!-- ===== ESTADO DE CARGA ===== -->
    @if (cargando)
    {
        <div style="text-align: center; padding: 80px 20px; color: #8B7355;">
            <div style="font-size: 3rem; margin-bottom: 16px;">🔄</div>
            <p style="font-size: 1.1rem; font-weight: 600;">Cargando catálogo...</p>
            <p style="font-size: 0.85rem; color: #B8A89A;">Conectando con la API del profesor</p>
        </div>
    }
    else if (errorApi)
    {
        <div style="background: #FFF3E0; border: 2px solid #FFB74D; border-radius: 12px; padding: 24px; text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 12px;">⚠️</div>
            <h3 style="color: #E65100;">No se pudo conectar con la API</h3>
            <p style="color: #8D6E63;">Verifica tu conexión a internet o intenta más tarde.</p>
            <button @onclick='() => FiltrarCategoria(categoriaActiva)'
                    style="margin-top: 16px; background: #8B6F47; color: white; border: none;
                    padding: 10px 24px; border-radius: 8px; cursor: pointer; font-weight: 600;">
                🔄 Reintentar
            </button>
        </div>
    }
    else if (productos.Count == 0)
    {
        <div style="text-align: center; padding: 60px; color: #8B7355;">
            <div style="font-size: 3rem; margin-bottom: 12px;">🔍</div>
            <p>No hay productos disponibles en esta categoría.</p>
        </div>
    }
    else
    {
        <p style="color: #8B7355; font-size: 0.9rem; margin-bottom: 20px; text-align: center;">
            Mostrando <strong style="color: #6B4F35;">@productos.Count</strong> producto(s)
        </p>

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
            @foreach (var producto in productos)
            {
                <div style="background: white; border-radius: 14px; overflow: hidden;
                    border: 2px solid #E8D5B7; box-shadow: 0 3px 10px rgba(139,111,71,0.1);">

                    <div style="background: linear-gradient(135deg, #F5E6D0, #E8D5B7);
                        padding: 24px; text-align: center; font-size: 3rem;">
                        @(producto.CategoriaId == 1 ? "👩" : "👨")
                    </div>

                    <div style="padding: 18px;">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                            <h3 style="color: #4A3728; font-size: 1rem; font-weight: 700; margin: 0; flex: 1;">
                                @producto.Nombre
                            </h3>
                            @if (producto.Disponible)
                            {
                                <span style="background: #E8F5E9; color: #2E7D32; font-size: 0.72rem;
                                    padding: 3px 8px; border-radius: 10px; font-weight: 600; white-space: nowrap; margin-left: 8px;">
                                    ✓ Disponible
                                </span>
                            }
                            else
                            {
                                <span style="background: #FFEBEE; color: #C62828; font-size: 0.72rem;
                                    padding: 3px 8px; border-radius: 10px; font-weight: 600; white-space: nowrap; margin-left: 8px;">
                                    Agotado
                                </span>
                            }
                        </div>

                        <p style="color: #8B7355; font-size: 0.85rem; margin: 0 0 12px; line-height: 1.5; min-height: 40px;">
                            @(string.IsNullOrEmpty(producto.Descripcion) ? "Sin descripción disponible." : producto.Descripcion)
                        </p>

                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                            <span style="font-size: 1.4rem; font-weight: 800; color: #6B4F35;">
                                $@producto.Precio.ToString("F2")
                            </span>
                            <span style="font-size: 0.8rem; color: #B8A89A;">
                                Stock: @producto.Stock
                            </span>
                        </div>

                        <span style="background: #F0E6D3; color: #8B6F47; font-size: 0.78rem;
                            padding: 4px 10px; border-radius: 10px; font-weight: 600;">
                            🏷️ @(producto.CategoriaId == 1 ? "Ropa de Mujer" : "Ropa de Hombre")
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ProductoApi> productos = new();
    private int categoriaActiva = 0;
    private bool cargando = true;
    private bool errorApi = false;

    protected override async Task OnInitializedAsync()
    {
        await FiltrarCategoria(0);
    }

    private async Task FiltrarCategoria(int categoriaId)
    {
        cargando = true;
        errorApi = false;
        categoriaActiva = categoriaId;

        try
        {
            var http = ClientFactory.CreateClient("ApiProfesor");

            List<ProductoApi>? resultado;

            if (categoriaId == 0)
            {
                // Carga ambas categorías y las combina
                var mujer = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/1");
                var hombre = await http.GetFromJsonAsync<List<ProductoApi>>("api/comercio/productos/categoria/2");
                resultado = new List<ProductoApi>();
                if (mujer != null) resultado.AddRange(mujer);
                if (hombre != null) resultado.AddRange(hombre);
            }
            else
            {
                resultado = await http.GetFromJsonAsync<List<ProductoApi>>($"api/comercio/productos/categoria/{categoriaId}");
            }

            productos = resultado ?? new List<ProductoApi>();
        }
        catch
        {
            productos = new List<ProductoApi>();
            errorApi = true;
        }

        cargando = false;
    }
}
